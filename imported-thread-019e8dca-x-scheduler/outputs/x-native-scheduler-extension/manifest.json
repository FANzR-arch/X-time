{
  "manifest_version": 3,
  "name": "X Native Scheduler Queue",
  "version": "0.1.0",
  "description": "Local-only queue assistant that schedules posts through X's native composer.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "X Native Scheduler Queue",
    "default_popup": "popup.html"
  }
}
