{
  "manifest_version": 3,
  "name": "X Native Scheduler Test Plugin",
  "version": "0.8.1",
  "description": "Local original-post and text-reply queues using X's native scheduler with selectable target timezones.",
  "permissions": [
    "activeTab",
    "alarms",
    "clipboardWrite",
    "debugger",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": [
        "reply-core.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "assets/plugin-logo-16.png",
    "32": "assets/plugin-logo-32.png",
    "48": "assets/plugin-logo-48.png",
    "128": "assets/plugin-logo-128.png"
  },
  "action": {
    "default_title": "X Native Scheduler Test Plugin",
    "default_icon": {
      "16": "assets/plugin-logo-16.png",
      "32": "assets/plugin-logo-32.png",
      "48": "assets/plugin-logo-48.png",
      "128": "assets/plugin-logo-128.png"
    }
  }
}
